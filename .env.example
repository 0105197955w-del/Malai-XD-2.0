# Bot identity
BOT_NAME=Malai-XD-2.0
OWNER_NAME=Malai Owner
OWNER_NUMBER=254105197055
PREFIX=.
MADE_BY=Kimani Samuel
TIME_ZONE=Africa/Nairobi

# Login: pair or qr
LOGIN_METHOD=pair
PAIRING_NUMBER=254105197055
SESSION_DIR=./session

# Pairing web endpoint: /code?number=254105197055
# Set false if you do not want web pairing enabled on Render/Railway.
PAIRING_WEB_ENABLED=true
# Optional token for /code and /pair endpoints.
# When set, open /code?number=254105197055&token=your-secret-token
PAIRING_AUTH_TOKEN=
# Optional external pairing API for owner-only .pair command after the bot is already linked.
PAIRING_API_URL=
# Optional custom Baileys browser tuple: Platform,Browser,Version
BROWSER=

# Hosting
PORT=3000
PUBLIC_MODE=true
CONNECT_NOTIFY=true
# Greet delay defaults to 20 minutes. For testing, use 60000 for 1 minute.
GREET_DELAY_MS=1200000
# Autobio refresh interval defaults to 10 minutes. Minimum is 60000.
AUTOBIO_INTERVAL_MS=600000
# Autotyping/autorecord fake presence duration. Works in private chats and groups when enabled.
AUTO_PRESENCE_DURATION_MS=12000

# Optional API keys
OPENAI_API_KEY=
NEWS_API_KEY=
WEATHER_API_KEY=
